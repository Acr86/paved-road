{
  "uid": "service-golden-signals",
  "title": "Service Golden Signals",
  "tags": ["paved-road", "service"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "service",
        "type": "query",
        "datasource": null,
        "query": "label_values(http_requests_total, service)",
        "refresh": 2,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Traffic — requests/s by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total{service=\"$service\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Errors — 5xx ratio (SLO threshold 0.5%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{service=\"$service\", status=~\"5..\"}[5m])) or vector(0)) / sum(rate(http_requests_total{service=\"$service\"}[5m]))",
          "legendFormat": "error ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.005 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency — p50 / p95 / p99 (SLO: p95 < 300ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"$service\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Saturation — CPU vs limit",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"$service.*\", container!=\"\"}[5m]))",
          "legendFormat": "usage (cores)",
          "refId": "A"
        },
        {
          "expr": "sum(kube_pod_container_resource_limits{pod=~\"$service.*\", resource=\"cpu\"})",
          "legendFormat": "limit",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Saturation — memory vs limit",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{pod=~\"$service.*\", container!=\"\"})",
          "legendFormat": "working set",
          "refId": "A"
        },
        {
          "expr": "sum(kube_pod_container_resource_limits{pod=~\"$service.*\", resource=\"memory\"})",
          "legendFormat": "limit",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    }
  ]
}
